# ZoneProof Oracle — environment variables
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres

# ── Hedera ────────────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=
HEDERA_EVM_ADDRESS=
HEDERA_PRIVATE_KEY=
ORACLE_ADDRESS=
REZONING_ORACLE_ADDRESS=
HCS_TOPIC_ID=

# ── Oracle API ────────────────────────────────────────────────────────────────
API_PORT=8001

# ── ENS resolution ────────────────────────────────────────────────────────────
ETH_NETWORK=sepolia

# ── Chainlink CRE ─────────────────────────────────────────────────────────────
CRE_ENV=staging

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
