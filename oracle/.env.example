# ZoneProof Oracle — environment variables
# Preferred production entry: oracle/server (combined Node) — see oracle/server/.env.example
#
#   cd oracle/server && npm install && npm start
#   Single Render Web Service: root oracle/server, start `npm start`

# ── Combined Node server (Render) ─────────────────────────────────────────────
# PORT is set by Render
API_PORT=8001
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=
HEDERA_EVM_ADDRESS=
HEDERA_PRIVATE_KEY=
X402_PRICE_TINYBARS=5000000
HCS_REPORT_AUDIT_TOPIC=
HCS_PETITION_LOG_TOPIC=
HTS_NFT_TOKEN_ID=
ORACLE_ENS=zoneproof.eth
ORACLE_ADDRESS=
REZONING_ORACLE_ADDRESS=
HCS_TOPIC_ID=

# ── Legacy Python API / scrapers (optional; not needed for combined server) ───
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
ETH_NETWORK=sepolia
CRE_ENV=staging
LOG_LEVEL=INFO
# HEDERA_SERVICE_URL no longer needed when using oracle/server (in-process Hedera)

