# ZoneProof combined Node server (Oracle API + Hedera) — single Render Web Service

# Render injects PORT — leave unset locally to use 8001
# PORT=8001
API_PORT=8001

# ── Hedera (optional for read-only API; required for x402 + HCS/HTS) ──────────
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.XXXXXXXX
HEDERA_EVM_ADDRESS=0x...
HEDERA_PRIVATE_KEY=0x...

# x402 payment gate (defaults match legacy if unset)
X402_PRICE_TINYBARS=5000000

# After POST /setup once, paste:
HCS_REPORT_AUDIT_TOPIC=
HCS_PETITION_LOG_TOPIC=
HTS_NFT_TOKEN_ID=

# Report seal uses HEDERA_EVM_ADDRESS as oracle_address (ECDSA)

# Optional legacy aliases
# HCS_TOPIC_ID=
# REZONING_ORACLE_ADDRESS=0x5b5E9443A254c850682d2f196aA59c9DDbfC4691
